{
  "name": "adt-extension",
  "displayName": "Adaptive Developer Twin (ADT)",
  "description": "Production-grade AI-orchestrated developer life-cycle management.",
  "version": "1.1.0",
  "publisher": "PurpleDrip",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/logo-whiteBg.jpg",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "adt.register",
        "title": "ADT: Register Developer"
      },
      {
        "command": "adt.status",
        "title": "ADT: View My Stats"
      }
    ],
    "configuration": {
      "title": "ADT",
      "properties": {
        "adt.gatewayUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "URL of the ADT API Gateway"
        },
        "adt.extensionId": {
          "type": "string",
          "default": "",
          "description": "Unique Extension ID from registration"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha --require ts-node/register --require test/setup.js \"test/unit/**/*.test.ts\" --timeout 10000",
    "test:integration": "mocha --require ts-node/register --require test/setup.js \"test/integration/**/*.test.ts\" --timeout 30000",
    "test:e2e": "node ./out/test/runTest.js",
    "package": "npm run compile && npx @vscode/vsce package --allow-missing-repository --out ../releases/",
    "package:pre": "npm run compile && npx @vscode/vsce package --pre-release --allow-missing-repository --out ../releases/"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/chai": "^4.3.20",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "@vscode/vsce": "^3.0.0",
    "chai": "^4.5.0",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "proxyquire": "^2.1.3",
    "sinon": "^17.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.4.0",
    "node-machine-id": "^1.1.12"
  }
}
