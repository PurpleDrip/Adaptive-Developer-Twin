{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ESNext", "DOM"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", ".vscode-test"]
}
