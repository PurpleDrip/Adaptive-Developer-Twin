# ─────────────────────────────────────────────
# Adaptive Developer Twin — Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Neo4j AuraDB ─────────────────────────────
# Format: neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=neo4j+s://REPLACE_ME.databases.neo4j.io
NEO4J_USER=REPLACE_ME
NEO4J_PASSWORD=REPLACE_ME

# ── MongoDB Atlas ─────────────────────────────
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGO_USER=REPLACE_ME
MONGO_PASSWORD=REPLACE_ME
MONGO_URI=mongodb+srv://REPLACE_ME:REPLACE_ME@REPLACE_ME.mongodb.net/adt_db?retryWrites=true&w=majority&appName=ADT

# ── Upstash Redis ─────────────────────────────
# REST API (used by some services for non-blocking pub/sub)
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME
# Standard Redis URL — must use rediss:// (TLS) for Upstash
REDIS_URL=rediss://default:REPLACE_ME@REPLACE_ME.upstash.io:6379

# ── Service URLs (local dev) ──────────────────
# These point services at each other when running locally via run_backend.ps1.
# Do not change these unless you run services on different ports.
AUTH_URL=http://127.0.0.1:8001
TELEMETRY_URL=http://127.0.0.1:8002
TASK_URL=http://127.0.0.1:8003
ANALYTICS_URL=http://127.0.0.1:8004
FUSION_URL=http://127.0.0.1:8005
MONITORING_URL=http://127.0.0.1:8007
THG_URL=http://127.0.0.1:8008
ALLOCATION_URL=http://127.0.0.1:8009

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins for the gateway.
# Add your frontend URL here if you deploy to a custom domain.
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:3000
