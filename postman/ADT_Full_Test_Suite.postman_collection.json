{
	"info": {
		"name": "ADT Platform — Full Workflow Test Suite",
		"description": "End-to-end test suite for the Adaptive Developer Twin platform.\n\nRun order: Health Checks → Auth → Developer → THG → Assessment → Analytics → Tasks → Security\n\nDirect Service URLs (bypass Gateway).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "AUTH", "value": "http://127.0.0.1:8001" },
		{ "key": "TASK", "value": "http://127.0.0.1:8003" },
		{ "key": "ANALYTICS", "value": "http://127.0.0.1:8004" },
		{ "key": "THG", "value": "http://127.0.0.1:8008" },
		{ "key": "GATEWAY", "value": "http://127.0.0.1:8000" },
		{ "key": "DEV_USERNAME", "value": "dev_1" },
		{ "key": "MGR_USERNAME", "value": "manager_1" },
		{ "key": "TECH_USERNAME", "value": "admin_root" },
		{ "key": "PASSWORD", "value": "demo123" },
		{ "key": "DEV_ID", "value": "" },
		{ "key": "MGR_ID", "value": "" },
		{ "key": "TEST_ID", "value": "TEST-PY-001" }
	],
	"item": [
		{
			"name": "01 — Health Checks",
			"item": [
				{
					"name": "Gateway Health",
					"request": { "method": "GET", "url": "{{GATEWAY}}/health" },
					"event": [{ "listen": "test", "script": { "exec": ["pm.test('Gateway alive', () => pm.response.to.have.status(200));"] } }]
				},
				{
					"name": "Auth Service Health",
					"request": { "method": "GET", "url": "{{AUTH}}/api/v1/auth/health" },
					"event": [{ "listen": "test", "script": { "exec": ["pm.test('Auth alive', () => pm.response.to.have.status(200));"] } }]
				},
				{
					"name": "Task Service Health",
					"request": { "method": "GET", "url": "{{TASK}}/api/v1/task/health" },
					"event": [{ "listen": "test", "script": { "exec": ["pm.test('Task alive', () => pm.response.to.have.status(200));"] } }]
				},
				{
					"name": "THG Service Health",
					"request": { "method": "GET", "url": "{{THG}}/api/v1/thg/health" },
					"event": [{ "listen": "test", "script": { "exec": ["pm.test('THG alive', () => pm.response.to.have.status(200));"] } }]
				},
				{
					"name": "Analytics Service Health",
					"request": { "method": "GET", "url": "{{ANALYTICS}}/api/v1/analytics/health" },
					"event": [{ "listen": "test", "script": { "exec": ["pm.test('Analytics alive', () => pm.response.to.have.status(200));"] } }]
				}
			]
		},
		{
			"name": "02 — Polymorphic Auth (Login)",
			"item": [
				{
					"name": "Login as Developer",
					"request": {
						"method": "POST",
						"url": "{{AUTH}}/api/v1/auth/users/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"{{DEV_USERNAME}}\",\n  \"password\": \"{{PASSWORD}}\"\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"var json = pm.response.json();",
						"pm.test('Login 200', () => pm.response.to.have.status(200));",
						"pm.test('Role is developer', () => pm.expect(json.role).to.equal('developer'));",
						"pm.test('Has user_id', () => pm.expect(json.user_id).to.exist);",
						"pm.collectionVariables.set('DEV_ID', json.user_id);"
					] } }]
				},
				{
					"name": "Login as Manager",
					"request": {
						"method": "POST",
						"url": "{{AUTH}}/api/v1/auth/users/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"{{MGR_USERNAME}}\",\n  \"password\": \"{{PASSWORD}}\"\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"var json = pm.response.json();",
						"pm.test('Login 200', () => pm.response.to.have.status(200));",
						"pm.test('Role is manager', () => pm.expect(json.role).to.equal('manager'));",
						"pm.collectionVariables.set('MGR_ID', json.user_id);"
					] } }]
				},
				{
					"name": "Login as Tech Admin",
					"request": {
						"method": "POST",
						"url": "{{AUTH}}/api/v1/auth/users/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"{{TECH_USERNAME}}\",\n  \"password\": \"{{PASSWORD}}\"\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"var json = pm.response.json();",
						"pm.test('Login 200', () => pm.response.to.have.status(200));",
						"pm.test('Role is tech', () => pm.expect(json.role).to.equal('tech'));"
					] } }]
				},
				{
					"name": "Login with WRONG password (should 401)",
					"request": {
						"method": "POST",
						"url": "{{AUTH}}/api/v1/auth/users/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"dev_1\",\n  \"password\": \"wrongpassword\"\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": ["pm.test('Should 401', () => pm.response.to.have.status(401));"] } }]
				},
				{
					"name": "Login with NON-EXISTENT user (should 401)",
					"request": {
						"method": "POST",
						"url": "{{AUTH}}/api/v1/auth/users/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"ghost_user\",\n  \"password\": \"demo123\"\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": ["pm.test('Should 401', () => pm.response.to.have.status(401));"] } }]
				}
			]
		},
		{
			"name": "03 — Developer Profile",
			"item": [
				{
					"name": "Get Developer Profile",
					"request": { "method": "GET", "url": "{{AUTH}}/api/v1/auth/users/profile/{{DEV_ID}}" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Profile 200', () => pm.response.to.have.status(200));",
						"pm.test('Has name', () => pm.expect(pm.response.json().name).to.exist);"
					] } }]
				},
				{
					"name": "Get Developer Tasks",
					"request": { "method": "GET", "url": "{{TASK}}/api/v1/task/user/{{DEV_ID}}" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Tasks 200', () => pm.response.to.have.status(200));",
						"pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
					] } }]
				}
			]
		},
		{
			"name": "04 — THG Graph Intelligence",
			"item": [
				{
					"name": "Get All Developers (Graph)",
					"request": { "method": "GET", "url": "{{THG}}/api/v1/thg/developers" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Returns 200', () => pm.response.to.have.status(200));",
						"pm.test('Has entries', () => pm.expect(pm.response.json().length).to.be.above(0));"
					] } }]
				},
				{
					"name": "Get Developer Skills",
					"request": { "method": "GET", "url": "{{THG}}/api/v1/thg/skills/{{DEV_ID}}" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Skills 200 or 404', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));"
					] } }]
				},
				{
					"name": "Get Influence Rankings (EVC-Influence)",
					"request": { "method": "GET", "url": "{{THG}}/api/v1/thg/influence" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Influence 200', () => pm.response.to.have.status(200));",
						"pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
					] } }]
				},
				{
					"name": "Get Leaderboard (Python)",
					"request": { "method": "GET", "url": "{{THG}}/api/v1/thg/leaderboard/Python" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Leaderboard 200', () => pm.response.to.have.status(200));"
					] } }]
				},
				{
					"name": "Match Task (CSA-Matching)",
					"request": {
						"method": "POST",
						"url": "{{THG}}/api/v1/thg/match",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"task_id\": \"MATCH-001\",\n  \"required_skills\": {\"Python\": 0.8, \"FastAPI\": 0.6}\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Match 200', () => pm.response.to.have.status(200));",
						"pm.test('Has candidates', () => pm.expect(pm.response.json().candidates).to.be.an('array'));"
					] } }]
				}
			]
		},
		{
			"name": "05 — Assessment Engine",
			"item": [
				{
					"name": "Get Active Assessments",
					"request": { "method": "GET", "url": "{{TASK}}/api/v1/task/assessment/active" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Returns 200', () => pm.response.to.have.status(200));",
						"var tests = pm.response.json();",
						"if (tests.length > 0) pm.collectionVariables.set('TEST_ID', tests[0].test_id);"
					] } }]
				},
				{
					"name": "Submit Assessment (First Attempt)",
					"request": {
						"method": "POST",
						"url": "{{TASK}}/api/v1/task/assessment/submit",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{DEV_ID}}\",\n  \"test_id\": \"{{TEST_ID}}\",\n  \"answers\": {\n    \"q1\": \"B\",\n    \"q2\": \"B\",\n    \"q3\": \"B\",\n    \"q4\": \"A\",\n    \"q5\": \"A\",\n    \"q6\": \"B\",\n    \"q7\": \"A\",\n    \"q8\": \"A\",\n    \"q9\": \"C\",\n    \"q10\": \"C\"\n  }\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"var json = pm.response.json();",
						"pm.test('Submit 200', () => pm.response.to.have.status(200));",
						"pm.test('Has score', () => pm.expect(json.score).to.be.a('number'));",
						"pm.test('Has delta', () => pm.expect(json.delta).to.be.a('number'));"
					] } }]
				},
				{
					"name": "Submit AGAIN (Anti-Cheat should 403)",
					"request": {
						"method": "POST",
						"url": "{{TASK}}/api/v1/task/assessment/submit",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{DEV_ID}}\",\n  \"test_id\": \"{{TEST_ID}}\",\n  \"answers\": {\"q1\":\"A\",\"q2\":\"A\",\"q3\":\"A\",\"q4\":\"A\",\"q5\":\"A\",\"q6\":\"A\",\"q7\":\"A\",\"q8\":\"A\",\"q9\":\"A\",\"q10\":\"A\"}\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Anti-Cheat blocks', () => pm.response.to.have.status(403));"
					] } }]
				}
			]
		},
		{
			"name": "06 — Analytics",
			"item": [
				{
					"name": "Developer Summary",
					"request": { "method": "GET", "url": "{{ANALYTICS}}/api/v1/analytics/stats/{{DEV_ID}}/summary" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Summary 200', () => pm.response.to.have.status(200));",
						"pm.test('Has rank', () => pm.expect(pm.response.json().overall_rank).to.exist);"
					] } }]
				},
				{
					"name": "Global Leaderboard",
					"request": { "method": "GET", "url": "{{ANALYTICS}}/api/v1/analytics/leaderboard?skill=Python" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Leaderboard 200', () => pm.response.to.have.status(200));",
						"pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
					] } }]
				}
			]
		},
		{
			"name": "07 — Task Management",
			"item": [
				{
					"name": "Get All Tasks",
					"request": { "method": "GET", "url": "{{TASK}}/api/v1/task/all" },
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Tasks 200', () => pm.response.to.have.status(200));",
						"pm.test('Has tasks', () => pm.expect(pm.response.json().length).to.be.above(0));"
					] } }]
				}
			]
		},
		{
			"name": "08 — Security Perimeter",
			"item": [
				{
					"name": "Hardware Lock (First Handshake)",
					"request": {
						"method": "POST",
						"url": "{{AUTH}}/api/v1/auth/users/validate-extension",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"extension_id\": \"ADT-DX-101\",\n  \"machine_id\": \"HWID-TEST-001\"\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Returns 200', () => pm.response.to.have.status(200));",
						"var json = pm.response.json();",
						"pm.test('Status is valid', () => pm.expect(json.status).to.be.oneOf(['LOCKED_TO_HARDWARE', 'VERIFIED']));"
					] } }]
				},
				{
					"name": "Hardware Lock (WRONG Machine — should 403)",
					"request": {
						"method": "POST",
						"url": "{{AUTH}}/api/v1/auth/users/validate-extension",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"extension_id\": \"ADT-DX-101\",\n  \"machine_id\": \"HWID-ATTACKER-999\"\n}" }
					},
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Mismatch 403', () => pm.response.to.have.status(403));"
					] } }]
				}
			]
		}
	]
}
